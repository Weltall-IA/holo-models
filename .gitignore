# Ignore all files by default
*

# Allow directories (needed for traversal)
!*/

# Allow tracked extensions only
!*.gitignore
!*.md
!*.py
!*.txt
!*.json
!*.jsonl
!*.yml
!*.yaml
!*.sh
!*.service
!*.socket
!*.jinja
!*.csv
!*.png
!*.jpg
!*.svg
!*.toml
!*.cfg
!*.conf

# Secrets - explicit block regardless of extension whitelist
.hf_token
.env
.env.*
*.env
*.secret
*.key
*.pem
**/secrets/
**/credentials/
**/private_key*

# Tokenizer files - too large to version
**/tokenizer.json

# Local benchmark runtime and regeneratable raw results
benchmarks/
**/.venv/
**/__pycache__/
**/*.pyc
**/results/raw/
**/cache/

# Database files - application state, not versioned
**/*.sqlite
**/*.sqlite3
**/_data/

# Runtime - code, dependencies, build output
runtime/vane-comparison/native-stack/node-v24.5.0-linux-x64/
runtime/vane-comparison/native-stack/vane/
runtime/vane-comparison/native-stack/searxng/
runtime/vane-comparison/native-stack/searxng-venv/
runtime/vane-comparison/native-stack/playwright-browsers/
runtime/vane-comparison/native-stack/downloads/
runtime/vane-comparison/native-stack/data/db.sqlite
runtime/vane-comparison/native-stack/logs/
runtime/vane-comparison/slimtoolkit/

# Standalone model dirs - various formats
standalone/

# Model weights and binary artifacts remain local
**/*.gguf
**/*.safetensors
**/*.bin
**/*.onnx
**/*.pt
**/*.pth
**/*.ckpt
**/*.engine
**/*.tar
**/*.tar.gz
**/*.tar.zst
**/*.zip
